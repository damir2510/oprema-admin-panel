import streamlit as st
import pandas as pd
import pymysql
import folium
from streamlit_folium import st_folium

# 1. Funkcija za povlačenje podataka (samo bitno za mapu)
def get_map_data():
    conn = pymysql.connect(
        host="mysql-22f7bcfd-nogalod-c393.d.aivencloud.com",
        user="avnadmin", password="AVNS_0qoNdSQVUuF9wTfHN8D",
        port=27698, database="defaultdb",
        cursorclass=pymysql.cursors.DictCursor,
        ssl={'ssl-mode': 'REQUIRED'}
    )
    with conn.cursor() as cursor:
        cursor.execute("SELECT inventarni_broj, naziv_proizvodjac, gps_koordinate, trenutni_radnik, status FROM oprema")
        result = cursor.fetchall()
    conn.close()
    return pd.DataFrame(result)

st.set_page_config(page_title="Mapa opreme", layout="wide")
st.title("📍 Interaktivna Mapa Opreme")

df = get_map_data()

# 2. Obrada GPS koordinata
# Pretpostavljamo da je format "lat, lon" (npr. "45.123, 19.456")
locations = []
for _, row in df.iterrows():
    gps = row['gps_koordinate']
    if gps and "," in str(gps):
        try:
            lat, lon = map(float, str(gps).split(','))
            locations.append({
                'lat': lat, 'lon': lon,
                'info': f"Inv: {row['inventarni_broj']} | {row['naziv_proizvodjac']}",
                'radnik': row['trenutni_radnik'],
                'status': row['status']
            })
        except: continue

if locations:
    # Centriramo mapu na prvu lokaciju
    m = folium.Map(location=[locations[0]['lat'], locations[0]['lon']], zoom_start=8)

    for loc in locations:
        # Boja čiode zavisi od statusa
        color = 'green' if loc['status'] == 'Ispravno' else 'red'

        folium.Marker(
            [loc['lat'], loc['lon']],
            popup=f"{loc['info']} (Kod: {loc['radnik']})",
            tooltip=loc['info'],
            icon=folium.Icon(color=color, icon='info-sign')
        ).add_to(m)

    st_folium(m, width=1200, height=600)
else:
    st.warning("Nema validnih GPS podataka u bazi za prikaz na mapi.")
